# =========================================================
# Variables de entorno — Mortalidad Buenos Aires
# Copia este archivo a .env y completa los valores.
# NUNCA subas .env al repositorio.
# =========================================================

# --- PostgreSQL ---
# Local: postgres://user:pass@localhost:5432/mortalidad
# Railway: pega el valor de ${{Postgres.DATABASE_URL}}
DATABASE_URL=postgresql+psycopg2://mortalidad:mortalidad@postgres:5432/mortalidad

# Credenciales solo para docker-compose local (postgres service)
POSTGRES_DB=mortalidad
POSTGRES_USER=mortalidad
POSTGRES_PASSWORD=mortalidad

# --- API ---
API_HOST=0.0.0.0
API_PORT=8000
# Origen permitido por CORS para el dashboard
DASHBOARD_ORIGIN=http://localhost:8501

# --- Dashboard ---
# URL pública o interna de la API que consume el dashboard
API_URL=http://api:8000

# --- ETL ---
CSV_PATH=/app/data/raw/defunciones-ocurridas-y-registradas-en-la-republica-argentina-entre-los-anos-2005-2022.csv
JURISDICCION_FOCO=Buenos Aires

# --- Fuente externa: API datos.gob.ar (INDEC población) ---
# Se usa el endpoint de series de tiempo de Datos Argentina.
# Doc: https://datosgobar.github.io/series-tiempo-ar-api/
INDEC_API_URL=https://apis.datos.gob.ar/series/api/series

# --- Modelos ML ---
MODEL_DIR=/app/data/models

# --- Logging ---
LOG_LEVEL=INFO
LOG_FORMAT=json
